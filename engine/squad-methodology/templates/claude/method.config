# Configuración de la metodología para este proyecto.
# La leen .claude/hooks/gate-merge.sh y los agentes integrator / qa-validator.
# Sintaxis shell (source-able). Sin comillas en TARGET_BRANCH (compara con string crudo).

TARGET_BRANCH=main

# Comandos del proyecto (qa-validator los corre por orden).
TYPECHECK_CMD="pnpm typecheck"
LINT_CMD=""
TEST_CMD="pnpm test"
BUILD_CMD="pnpm build"
