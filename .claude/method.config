# Configuración de la metodología para este proyecto.
# Lo leen .claude/hooks/gate-merge.sh y los agentes integrator / qa-validator.
# Sintaxis shell (source-able). NO comillas en TARGET_BRANCH (compara con string crudo).

# Rama destino de integración.
TARGET_BRANCH=main

# Comandos del proyecto (qa-validator los corre por orden).
TYPECHECK_CMD="cd app && pnpm tsc --noEmit"
LINT_CMD=""
TEST_CMD="cargo test --workspace"
BUILD_CMD="cargo build --workspace"
