# Copy to app/.env.local or app/src-tauri/.env.local for local builds.
# Never commit real values.

# In-app "Report bug" issues
LINEAR_API_KEY=lin_api_your_key
LINEAR_TEAM_ID=your-linear-team-uuid
LINEAR_BUG_LABEL_NAME=User Bug

# Houston Credits — free trial provider (Haiku, owner-pays model)
# Baked in at compile time via option_env!(); also read at runtime via std::env::var.
# For local dev: export HOUSTON_CREDITS_KEY=sk-ant-api03-... before pnpm tauri dev
# For CI/production: add as a GitHub Actions secret named HOUSTON_CREDITS_KEY
HOUSTON_CREDITS_KEY=sk-ant-api03-your_key_here

# Optional product infrastructure
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
SENTRY_DSN=
