{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sprints",
  "description": "List of sprints for a dev agent. Each sprint contains a set of stories.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "status"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string", "description": "Sprint name, e.g. 'Sprint 12' or 'Q2 Auth Hardening'" },
      "goal": { "type": "string", "description": "Sprint goal — one sentence describing the outcome." },
      "status": {
        "type": "string",
        "enum": ["planning", "active", "completed", "cancelled"],
        "description": "Current sprint state."
      },
      "start_date": { "type": ["string", "null"], "format": "date" },
      "end_date": { "type": ["string", "null"], "format": "date" },
      "created_at": { "type": "string", "format": "date-time" },
      "updated_at": { "type": "string", "format": "date-time" }
    },
    "additionalProperties": false
  }
}
