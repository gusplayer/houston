{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "description": "Per-agent config (model, provider, etc.).",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "provider": { "type": "string", "enum": ["anthropic", "openai"] },
    "model": { "type": "string" },
    "effort": { "type": "string", "enum": ["low", "medium", "high"] },
    "projectIds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Workspace project IDs this agent is bound to. Empty or unset = sees all workspace projects (CTO mode)."
    }
  },
  "additionalProperties": true
}
