---
pagination:
  data: storeCatalog
  size: 1
  alias: agent
permalink: "/store/agent/{{ agent.id }}/index.html"
rootPath: "../../../"
eleventyComputed:
  title: "{{ agent.name }} on Houston Store"
  description: "{{ agent.description }}"
---
{% extends "base.njk" %}
{% block title %}{{ agent.name }} on Houston Store{% endblock %}
{% block meta %}
<meta name="description" content="{{ agent.description }}">
<meta property="og:type" content="website">
<meta property="og:url" content="https://gethouston.ai/store/agent/{{ agent.id }}/">
<meta property="og:title" content="{{ agent.name }} on Houston Store">
<meta property="og:description" content="{{ agent.description }}">
<meta property="og:site_name" content="Houston">
<meta name="twitter:card" content="summary_large_image">
{% endblock %}
{% block favicon %}<link rel="icon" type="image/svg+xml" href="../../../favicon.svg">{% endblock %}
{% block inlineStyles %}
<style>
  :root {
    --background: #ffffff;
    --foreground: #0d0d0d;
    --muted-foreground: #5d5d5d;
    --border: #e5e5e5;
    --gray-50: #f9f9f9;
    --gray-100: #ececec;
    --gray-200: #e3e3e3;
    --gray-300: #cdcdcd;
    --gray-400: #b4b4b4;
    --gray-500: #9b9b9b;
    --gray-600: #676767;
    --gray-700: #424242;
    --gray-950: #0d0d0d;
    --success: #00a240;
    --info: #2964aa;
    --border-light: rgba(13,13,13,0.05);
    --border-medium: rgba(0,0,0,0.15);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: ui-sans-serif, -apple-system, system-ui, "Segoe UI", Helvetica, Arial, sans-serif;
    color: var(--foreground);
    background: var(--background);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
    padding-top: 65px;
  }
  a { color: inherit; text-decoration: none; }

  /* ── Nav (light) ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 16px 40px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  nav.scrolled { border-bottom-color: var(--border-light); }
  .nav-logo {
    font-family: 'General Sans', sans-serif;
    font-size: 22px; font-weight: 500; letter-spacing: -0.02em;
    color: var(--gray-950);
  }
  .nav-center {
    position: absolute; left: 50%; transform: translateX(-50%);
    display: flex; gap: 32px; align-items: center;
  }
  .nav-center a { font-size: 14px; color: var(--gray-700); transition: color 0.15s; }
  .nav-center a:hover { color: var(--gray-950); }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .nav-right a:not(.btn) { color: var(--gray-700); display: inline-flex; align-items: center; transition: color 0.15s; }
  .nav-right a:not(.btn):hover { color: var(--gray-950); }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0 16px; height: 36px; border-radius: 10px;
    font-size: 14px; font-weight: 500;
    border: 1px solid transparent; cursor: pointer;
    transition: all 0.15s;
  }
  .btn-primary { background: var(--gray-950); color: white; border-color: var(--gray-950); }
  .btn-primary:hover { background: black; }
  .btn-outline { background: white; color: var(--gray-950); border-color: var(--border-medium); }
  .btn-outline:hover { background: var(--gray-50); }
  .btn-lg { height: 46px; padding: 0 24px; font-size: 15px; border-radius: 12px; }

  /* ── Page ── */
  .container {
    max-width: 960px; margin: 0 auto;
    padding: 24px 40px 96px;
  }
  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--gray-500);
    margin-bottom: 32px;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--gray-950); }

  /* Hero block */
  .agent-hero {
    display: flex; align-items: flex-start; gap: 24px;
    margin-bottom: 28px;
  }
  .agent-icon {
    flex-shrink: 0;
    width: 80px; height: 80px;
    border-radius: 20px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'General Sans', sans-serif;
    font-weight: 600;
    font-size: 30px;
    color: white;
    letter-spacing: -0.02em;
  }
  .agent-head { flex: 1; min-width: 0; }
  .agent-name {
    font-family: 'General Sans', sans-serif;
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--gray-950);
    margin-bottom: 6px;
    display: flex; align-items: center; gap: 10px;
    flex-wrap: wrap;
  }
  .agent-publisher {
    font-size: 14px; color: var(--gray-600);
  }
  .agent-publisher a {
    color: var(--gray-950);
    border-bottom: 1px solid var(--gray-300);
    transition: border-color 0.15s;
  }
  .agent-publisher a:hover { border-bottom-color: var(--gray-950); }
  .verified-tick {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    color: var(--info);
  }

  .badges {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin-bottom: 20px;
  }
  .badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 12px; font-weight: 500;
  }
  .badge-official { background: rgba(41,100,170,0.08); color: var(--info); }
  .badge-community { background: var(--gray-100); color: var(--gray-700); }
  .badge-paid { background: rgba(0,162,64,0.08); color: var(--success); }
  .badge-verified { background: rgba(41,100,170,0.08); color: var(--info); }

  .description {
    font-size: 17px; color: var(--gray-700); line-height: 1.6;
    max-width: 720px;
    margin-bottom: 32px;
  }

  /* Install panel */
  .install-panel {
    background: var(--gray-50);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 28px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .install-panel-text { flex: 1; min-width: 200px; }
  .install-panel-text h3 {
    font-family: 'General Sans', sans-serif;
    font-size: 18px; font-weight: 600; letter-spacing: -0.015em;
    color: var(--gray-950);
    margin-bottom: 4px;
  }
  .install-panel-text p {
    font-size: 13.5px; color: var(--gray-600);
  }
  .install-panel-text p a {
    color: var(--gray-950);
    border-bottom: 1px solid var(--gray-300);
  }
  .install-panel-text p a:hover { border-bottom-color: var(--gray-950); }
  .price-tag {
    font-family: 'General Sans', sans-serif;
    font-size: 22px; font-weight: 600; letter-spacing: -0.02em;
    color: var(--success);
    margin-bottom: 4px;
  }
  .install-panel-actions { display: flex; gap: 12px; align-items: center; }

  /* Info grid */
  .info-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .info-card {
    padding: 22px;
    border: 1px solid var(--border-light);
    border-radius: 14px;
  }
  .info-card h4 {
    font-family: 'General Sans', sans-serif;
    font-size: 12px; font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--gray-500);
    margin-bottom: 14px;
  }
  .pill-list { display: flex; flex-wrap: wrap; gap: 6px; }
  .pill {
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--gray-100);
    color: var(--gray-700);
  }
  .info-card .publisher-row {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 6px;
  }
  .info-card .pub-name {
    font-size: 14px; font-weight: 500; color: var(--gray-950);
  }
  .info-card .pub-handle {
    font-size: 13px; color: var(--gray-500);
  }
  .info-card a.text-link {
    font-size: 13px;
    color: var(--gray-700);
    display: inline-flex; align-items: center; gap: 4px;
    border-bottom: 1px solid var(--gray-300);
    margin-top: 4px;
    transition: border-color 0.15s, color 0.15s;
  }
  .info-card a.text-link:hover { color: var(--gray-950); border-bottom-color: var(--gray-950); }
  .meta-line { font-size: 13px; color: var(--gray-600); margin-bottom: 6px; }
  .meta-line strong { color: var(--gray-950); font-weight: 500; }

  /* Stars */
  .stars {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 13px; font-weight: 500;
    color: var(--gray-700);
  }
  .stars svg { width: 14px; height: 14px; color: #f5a623; }
  .stars-faint { color: var(--gray-500); font-weight: 400; }

  /* Source link */
  .source-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14px; color: var(--gray-700);
    border-bottom: 1px solid var(--gray-300);
    padding-bottom: 2px;
  }
  .source-link:hover { color: var(--gray-950); border-bottom-color: var(--gray-950); }

  /* Responsive */
  @media (max-width: 768px) {
    nav { padding: 14px 20px; }
    .nav-center { display: none; }
    .container { padding: 24px 20px 64px; }
    .agent-hero { flex-direction: column; gap: 18px; }
    .agent-icon { width: 64px; height: 64px; font-size: 24px; border-radius: 16px; }
    .install-panel { padding: 20px; flex-direction: column; align-items: stretch; }
    .install-panel-actions { flex-direction: column; align-items: stretch; }
    .install-panel-actions .btn { width: 100%; justify-content: center; }
    .info-grid { grid-template-columns: 1fr; }
  }
</style>
{% endblock %}
{% block body %}
<nav>
  <a href="../../../" class="nav-logo">Houston</a>
  <div class="nav-center">
    <a href="../../../#agents">Agents</a>
    <a href="../../../#features">Features</a>
    <a href="../../../changelog/">Changelog</a>
    <a href="../../../startups/">For Startups</a>
    <a href="../../../store/">Store</a>
  </div>
  <div class="nav-right">
    <a href="https://github.com/gethouston/houston" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
    </a>
    <a class="btn btn-primary" href="../../../">Download</a>
  </div>
</nav>

<div class="container">
  <a class="back-link" href="../../../store/">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="14" height="14"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    All agents
  </a>

  {% set initials = agent.name.charAt(0) | upper %}
  {% set hash = agent.id.length * 53 %}
  {% set hue = hash % 360 %}

  <div class="agent-hero">
    <div class="agent-icon" style="background: hsl({{ hue }}, 62%, 48%);">{{ initials }}</div>
    <div class="agent-head">
      <h1 class="agent-name">
        {{ agent.name }}
        {% if agent.publisher.verified %}
          <span class="verified-tick" title="Verified publisher">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 1l2.39 4.84L20 6.5l-3.99 3.89.94 5.49L12 13.27 7.05 15.88l.94-5.49L4 6.5l5.61-.66L12 1z"/></svg>
          </span>
        {% endif %}
      </h1>
      <div class="agent-publisher">
        by
        {% if agent.publisher and agent.publisher.github_url %}
          <a href="{{ agent.publisher.github_url }}" target="_blank" rel="noopener noreferrer">{{ agent.publisher.name }}</a>
        {% elif agent.publisher %}
          {{ agent.publisher.name }}
        {% else %}
          {{ agent.author }}
        {% endif %}
        <span style="color: var(--gray-400);"> ·  </span>
        v{{ agent.version }}
        <span style="color: var(--gray-400);"> ·  </span>
        {{ agent.installs }} installs
        {% if agent.rating %}
          <span style="color: var(--gray-400);"> ·  </span>
          <span class="stars" style="display: inline-flex;">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1l2.39 4.84L20 6.5l-3.99 3.89.94 5.49L12 13.27 7.05 15.88l.94-5.49L4 6.5l5.61-.66L12 1z"/></svg>
            {{ agent.rating }}
            <span class="stars-faint">({{ agent.reviews_count }})</span>
          </span>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="badges">
    {% if agent.source == "houston" %}
      <span class="badge badge-official">Official</span>
    {% else %}
      <span class="badge badge-community">Community</span>
    {% endif %}
    {% if agent.publisher.verified %}
      <span class="badge badge-verified">Verified publisher</span>
    {% endif %}
    {% if agent.pricing.kind == "paid" %}
      <span class="badge badge-paid">
        ${{ (agent.pricing.price_cents / 100) | round }}{% if agent.pricing.model == "subscription" %}/month{% else %} one time{% endif %}
      </span>
    {% else %}
      <span class="badge badge-community">Free</span>
    {% endif %}
  </div>

  <p class="description">{{ agent.description }}</p>

  <div class="install-panel">
    <div class="install-panel-text">
      {% if agent.pricing.kind == "paid" %}
        <div class="price-tag">
          ${{ (agent.pricing.price_cents / 100) | round }}{% if agent.pricing.model == "subscription" %} / month{% else %} one time{% endif %}
        </div>
      {% endif %}
      <h3>Install with one click</h3>
      <p>Don't have Houston yet? <a href="../../../">Download for free</a>.</p>
    </div>
    <div class="install-panel-actions">
      <a class="btn btn-primary btn-lg" href="houston://store/agent/{{ agent.id }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Open in Houston
      </a>
    </div>
  </div>

  <div class="info-grid">
    <div class="info-card">
      <h4>Integrations</h4>
      {% if agent.integrations.length %}
        <div class="pill-list">
          {% for int in agent.integrations %}
            <span class="pill">{{ int }}</span>
          {% endfor %}
        </div>
      {% else %}
        <p style="font-size: 13px; color: var(--gray-500);">No connections required.</p>
      {% endif %}
    </div>

    <div class="info-card">
      <h4>Tags</h4>
      {% if agent.tags.length %}
        <div class="pill-list">
          {% for tag in agent.tags %}
            <span class="pill">{{ tag }}</span>
          {% endfor %}
        </div>
      {% else %}
        <p style="font-size: 13px; color: var(--gray-500);">No tags.</p>
      {% endif %}
    </div>

    <div class="info-card">
      <h4>Publisher</h4>
      <div class="publisher-row">
        <span class="pub-name">
          {% if agent.publisher %}{{ agent.publisher.name }}{% else %}{{ agent.author }}{% endif %}
        </span>
        {% if agent.publisher.verified %}
          <span class="verified-tick" title="Verified publisher" style="width: 16px; height: 16px;">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 1l2.39 4.84L20 6.5l-3.99 3.89.94 5.49L12 13.27 7.05 15.88l.94-5.49L4 6.5l5.61-.66L12 1z"/></svg>
          </span>
        {% endif %}
      </div>
      {% if agent.publisher %}
        <div class="pub-handle">@{{ agent.publisher.handle }}</div>
        {% if agent.publisher.github_url %}
          <a class="text-link" href="{{ agent.publisher.github_url }}" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            Visit on GitHub
          </a>
        {% endif %}
      {% endif %}
    </div>
  </div>

  {% if agent.repo or agent.publisher.github_url %}
    <a class="source-link"
       href="{% if agent.publisher.github_url %}{{ agent.publisher.github_url }}{% else %}https://github.com/{{ agent.repo }}{% endif %}"
       target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      View source on GitHub
    </a>
  {% endif %}
</div>

{% include "footer-landing.njk" %}

<script>
  (function() {
    var nav = document.querySelector('nav');
    if (!nav) return;
    function check() { nav.classList.toggle('scrolled', window.scrollY > 10); }
    window.addEventListener('scroll', check, { passive: true });
    check();
  })();
</script>
{% endblock %}
