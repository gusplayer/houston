---
pagination:
  data: storeCatalog
  size: 1
  alias: agent
permalink: "/store/agent/{{ agent.id }}/index.html"
rootPath: "../../../"
eleventyComputed:
  title: "{{ agent.name }} on Houston Store"
  description: "{{ agent.description }}"
---
{% extends "base.njk" %}
{% block title %}{{ agent.name }} on Houston Store{% endblock %}
{% block meta %}
<meta name="description" content="{{ agent.description }}">
<meta property="og:type" content="website">
<meta property="og:url" content="https://gethouston.ai/store/agent/{{ agent.id }}/">
<meta property="og:title" content="{{ agent.name }} on Houston Store">
<meta property="og:description" content="{{ agent.description }}">
<meta property="og:site_name" content="Houston">
<meta name="twitter:card" content="summary_large_image">
{% endblock %}
{% block favicon %}<link rel="icon" type="image/svg+xml" href="../../../favicon.svg">{% endblock %}
{% block stylesheets %}
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@500,600,700&display=swap" rel="stylesheet">
{% endblock %}
{% block inlineStyles %}
<style>
  :root {
    --background: #ffffff;
    --foreground: #0d0d0d;
    --muted-foreground: #5d5d5d;
    --border: #e5e5e5;
    --gray-50: #f9f9f9;
    --gray-100: #ececec;
    --gray-200: #e3e3e3;
    --gray-300: #cdcdcd;
    --gray-400: #b4b4b4;
    --gray-500: #9b9b9b;
    --gray-600: #676767;
    --gray-700: #424242;
    --gray-950: #0d0d0d;
    --success: #00a240;
    --info: #2964aa;
    --border-light: rgba(13,13,13,0.05);
    --border-medium: rgba(0,0,0,0.15);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: ui-sans-serif, -apple-system, system-ui, "Segoe UI", Helvetica, Arial, sans-serif;
    color: var(--foreground);
    background: var(--background);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
    padding-top: 65px;
  }
  a { color: inherit; text-decoration: none; }

  /* ── Nav (light) ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 16px 40px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  nav.scrolled { border-bottom-color: var(--border-light); }
  .nav-logo {
    font-family: 'General Sans', sans-serif;
    font-size: 22px; font-weight: 500; letter-spacing: -0.02em;
    color: var(--gray-950);
  }
  .nav-center {
    position: absolute; left: 50%; transform: translateX(-50%);
    display: flex; gap: 32px; align-items: center;
  }
  .nav-center a { font-size: 14px; color: var(--gray-700); transition: color 0.15s; }
  .nav-center a:hover { color: var(--gray-950); }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .nav-right a:not(.btn) { color: var(--gray-700); display: inline-flex; align-items: center; transition: color 0.15s; }
  .nav-right a:not(.btn):hover { color: var(--gray-950); }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0 16px; height: 36px; border-radius: 10px;
    font-size: 14px; font-weight: 500;
    border: 1px solid transparent; cursor: pointer;
    transition: all 0.15s;
  }
  .btn-primary { background: var(--gray-950); color: white; border-color: var(--gray-950); }
  .btn-primary:hover { background: black; }
  .btn-outline {
    background: white; color: var(--gray-950);
    border-color: var(--border-medium);
  }
  .btn-outline:hover { background: var(--gray-50); }
  .btn-lg { height: 44px; padding: 0 20px; font-size: 15px; border-radius: 12px; }

  /* ── Page container ── */
  .detail-wrap { max-width: 760px; margin: 0 auto; padding: 56px 40px 80px; }
  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--gray-600);
    margin-bottom: 20px;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--gray-950); }

  /* ── Detail card: flat white with subtle elevation ── */
  .detail-card {
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 4px 24px rgba(13, 13, 13, 0.04);
  }

  /* ── Title row ── */
  .detail-title-row {
    display: flex; align-items: center; justify-content: flex-start;
    gap: 12px; flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .detail-title {
    font-family: 'General Sans', sans-serif;
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--foreground);
    margin-right: 4px;
  }
  .detail-badges {
    display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
  }
  .badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px; height: 22px;
    border-radius: 999px;
    font-size: 11px; font-weight: 500; line-height: 1;
  }
  .badge-official  { background: rgba(41,100,170,0.10); color: #2964aa; }
  .badge-community { background: var(--gray-100);       color: var(--gray-700); }
  .badge-verified  { background: rgba(0,162,64,0.10);   color: #00a240; }
  .badge-paid      { background: rgba(245,166,35,0.14); color: #b46a00; }
  .badge-preview   { background: rgba(245,166,35,0.12); color: #b46a00; }
  .badge svg { width: 11px; height: 11px; }

  /* ── Publisher line ── */
  .detail-publisher {
    font-size: 14px; color: var(--gray-500);
    margin-bottom: 12px;
  }
  .detail-publisher a {
    color: var(--gray-700);
    border-bottom: 1px solid var(--border-medium);
  }
  .detail-publisher .version {
    color: var(--gray-500); margin-left: 12px; font-size: 13px;
  }

  /* ── Stats row ── */
  .detail-stats {
    display: flex; align-items: center; gap: 16px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 24px;
    flex-wrap: wrap;
    font-size: 13.5px; color: var(--gray-600);
  }
  .detail-stats .stars { display: inline-flex; align-items: center; gap: 4px; color: var(--gray-700); font-weight: 500; }
  .detail-stats .stars svg { width: 14px; height: 14px; color: #f5a623; }
  .detail-stats .reviews { color: var(--gray-500); font-weight: 400; }
  .detail-stats .installs { display: inline-flex; align-items: center; gap: 6px; color: var(--gray-700); font-weight: 500; }
  .detail-stats .installs svg { width: 14px; height: 14px; color: var(--gray-600); }
  .detail-stats .gh-link { display: inline-flex; align-items: center; gap: 6px; color: var(--gray-700); transition: color 0.15s; }
  .detail-stats .gh-link:hover { color: var(--gray-950); }
  .detail-stats .gh-link svg { width: 16px; height: 16px; }
  .detail-stats .dot { color: var(--gray-300); }

  /* ── Description prose ── */
  .detail-desc {
    font-size: 17px;
    color: var(--gray-700);
    line-height: 1.65;
    max-width: 65ch;
    margin: 24px 0 32px;
  }

  /* ── Sections ── */
  .detail-section { margin-bottom: 28px; }
  .detail-section-label {
    font-size: 11px; font-weight: 500;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .detail-integrations { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; }
  .detail-integrations .int-icon {
    display: inline-block;
    width: 24px; height: 24px;
    line-height: 0;
    opacity: 0.95;
    transition: transform 0.15s, opacity 0.15s;
  }
  .detail-integrations .int-icon:hover { transform: scale(1.08); opacity: 1; }
  .detail-integrations .int-icon svg { width: 100%; height: 100%; display: block; }
  .detail-integrations .int-pill-text {
    display: inline-flex; align-items: center;
    height: 28px; padding: 0 12px;
    border-radius: 8px;
    font-size: 12.5px;
    color: var(--gray-700);
    background: var(--gray-50);
    border: 1px solid var(--border-light);
  }

  .detail-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .detail-tag {
    padding: 4px 12px; height: 26px; border-radius: 999px;
    font-size: 12.5px; font-weight: 500;
    color: var(--gray-700);
    background: var(--gray-50);
    border: 1px solid var(--border-light);
    display: inline-flex; align-items: center;
  }

  /* ── CTA ── */
  .detail-cta-row {
    display: flex;
    justify-content: flex-end;
    padding-top: 24px;
    border-top: 1px solid var(--border-light);
    margin-top: 12px;
  }
  .btn-install {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0 24px; height: 48px;
    border-radius: 12px;
    font-size: 15px; font-weight: 500;
    background: var(--gray-950); color: white;
    border: 1px solid var(--gray-950);
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
  }
  .btn-install:hover { background: black; }
  .btn-install:active { transform: scale(0.98); }
  .btn-install.is-disabled {
    background: var(--gray-400); border-color: var(--gray-400);
    cursor: not-allowed; opacity: 0.95;
  }
  .btn-install.is-disabled:hover { background: var(--gray-400); }
  .btn-install svg { width: 14px; height: 14px; }

  /* ── Publish strip (below card) ── */
  .publish-strip {
    max-width: 1100px;
    margin: 0 auto 64px;
    padding: 28px 40px;
    background: var(--gray-50);
    border: 1px solid var(--border-light);
    border-radius: 20px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
  }
  .publish-strip h3 {
    font-family: 'General Sans', sans-serif;
    font-size: 20px; font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--gray-950);
    margin-bottom: 4px;
  }
  .publish-strip p {
    font-size: 14px;
    color: var(--gray-600);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    nav { padding: 14px 20px; }
    .nav-center { display: none; }
    .detail-wrap { padding: 40px 20px 64px; }
    .detail-card { padding: 28px 24px; border-radius: 16px; }
    .publish-strip {
      flex-direction: column;
      align-items: flex-start;
      margin-left: 20px; margin-right: 20px;
      padding: 24px;
    }
  }
</style>
{% endblock %}
{% block body %}
<nav>
  <a href="../../../" class="nav-logo">Houston</a>
  <div class="nav-center">
    <a href="../../../#agents">Agents</a>
    <a href="../../../#features">Features</a>
    <a href="../../../changelog/">Changelog</a>
    <a href="../../../startups/">For Startups</a>
    <a href="../../../store/">Store</a>
  </div>
  <div class="nav-right">
    <a href="https://github.com/gethouston/houston" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
    </a>
    <a class="btn btn-primary" href="../../../">Download</a>
  </div>
</nav>

<div class="detail-wrap">
  <a class="back-link" href="../../../store/">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="14" height="14"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    All agents
  </a>

  <div class="detail-card">
    {# ── Title row: name + badges (inline) ── #}
    <div class="detail-title-row">
      <h1 class="detail-title">{{ agent.name }}</h1>
      <div class="detail-badges">
        {% if agent.source == "houston" %}
          <span class="badge badge-official">Official</span>
        {% else %}
          <span class="badge badge-community">Community</span>
        {% endif %}
        {% if agent.publisher.verified %}
          <span class="badge badge-verified">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Verified
          </span>
        {% endif %}
        {% if agent.pricing.kind == "paid" %}
          <span class="badge badge-paid">
            ${{ (agent.pricing.price_cents / 100) | round }}{% if agent.pricing.model == "subscription" %}/mo{% endif %}
          </span>
        {% endif %}
        {% if agent.source == "mock" %}
          <span class="badge badge-preview" title="Design preview, not yet installable">Design preview</span>
        {% endif %}
      </div>
    </div>

    {# ── Publisher + version ── #}
    <div class="detail-publisher">
      Published by
      {% if agent.publisher and agent.publisher.github_url %}
        <a href="{{ agent.publisher.github_url }}" target="_blank" rel="noopener noreferrer">{{ agent.publisher.name }}</a>
      {% elif agent.publisher %}
        {{ agent.publisher.name }}
      {% else %}
        {{ agent.author }}
      {% endif %}
      {% if agent.version %}
        <span class="version">OSS Version {{ agent.version }}</span>
      {% endif %}
    </div>

    {# ── Stats row ── #}
    <div class="detail-stats">
      {% if agent.rating %}
        <span class="stars">
          <svg viewBox="0 0 24 24" fill="#f5a623" aria-hidden="true"><path d="M12 1l2.39 4.84L20 6.5l-3.99 3.89.94 5.49L12 13.27 7.05 15.88l.94-5.49L4 6.5l5.61-.66L12 1z"/></svg>
          {{ agent.rating }}
          {% if agent.reviews_count %}<span class="reviews">({{ agent.reviews_count }})</span>{% endif %}
        </span>
        <span class="dot">·</span>
      {% endif %}
      <span class="installs">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        {{ agent.installs }} installs
      </span>
      {% if agent.repo or agent.publisher.github_url %}
        <span class="dot">·</span>
        <a class="gh-link"
           href="{% if agent.publisher.github_url %}{{ agent.publisher.github_url }}{% else %}https://github.com/{{ agent.repo }}{% endif %}"
           target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View on GitHub
        </a>
      {% endif %}
    </div>

    {# ── Description ── #}
    <p class="detail-desc">{{ agent.description }}</p>

    {# ── Integrations ── #}
    {% if agent.integrations.length %}
      <div class="detail-section">
        <div class="detail-section-label">Integrations</div>
        <div class="detail-integrations">
          {% for int in agent.integrations %}{% set name = int %}{% include "integration-icon.njk" %}{% endfor %}
        </div>
      </div>
    {% endif %}

    {# ── Tags ── #}
    {% if agent.tags.length %}
      <div class="detail-section">
        <div class="detail-section-label">Tags</div>
        <div class="detail-tags">
          {% for tag in agent.tags %}
            <span class="detail-tag">{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {# ── CTA bottom-right ── #}
    <div class="detail-cta-row">
      {% if agent.source == "mock" %}
        <button class="btn-install is-disabled" disabled>Preview, not yet available</button>
      {% else %}
        <a class="btn-install" href="houston://store/agent/{{ agent.id }}">
          Install in Houston
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{# ── Publish strip (below card) ── #}
<div class="publish-strip">
  <div>
    <h3>Build, share, monetize.</h3>
    <p>Houston is open. Publish your own agent and the best ones rise to the top.</p>
  </div>
  <a class="btn btn-outline btn-lg" href="../../../store/publish/">Read the publishing guide</a>
</div>

{% include "footer-landing.njk" %}

<script>
  (function() {
    var nav = document.querySelector('nav');
    if (!nav) return;
    function check() { nav.classList.toggle('scrolled', window.scrollY > 10); }
    window.addEventListener('scroll', check, { passive: true });
    check();
  })();
</script>
{% endblock %}
